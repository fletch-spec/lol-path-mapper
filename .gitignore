# Generated output images (keep dir, ignore contents)
/outputs/*
!/outputs/.gitkeep

# Cache (downloaded/generated game data) — keep dir, ignore contents
/cache/*
!/cache/.gitkeep

# Replay files
/replays/*.rofl

# Dev assets (map image, replay files, API key, calibration data)
/.dev/

# Python bytecode cache
__pycache__/
*.py[cod]

.git
/.claude
