# =========================================================================
# The Summoner's Chronicle - Development Configuration (Local Overrides)
# =========================================================================
# This file is for LOCAL DEVELOPMENT ONLY - do NOT commit to version control
# Copy this file to development.cfg.local and fill in your own values
#
# Instructions:
#   1. cp development.cfg.local.example development.cfg.local
#   2. Update values with your actual credentials
#   3. Add development.cfg.local to .gitignore
#   4. Never commit development.cfg.local
#
# =========================================================================

# REQUIRED: Riot Games API Key
# Get your key from: https://developer.riotgames.com/
[api_integration]
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# REQUIRED: Security Keys (generate with: python -c "import secrets; print(secrets.token_hex(32))")
[security]
SECRET_KEY=your-generated-secret-key-here-min-32-chars
JWT_SECRET=your-generated-jwt-secret-key-here-min-32-chars

# OPTIONAL: OAuth2 Credentials (if using Riot OAuth)
[security]
OAUTH_CLIENT_ID=your-oauth-client-id-here
OAUTH_CLIENT_SECRET=your-oauth-client-secret-here

# OPTIONAL: AI Assistance API Key
[ai_assistance]
AI_API_KEY=sk-your-claude-api-key-here

# OPTIONAL: Error Tracking (Sentry)
[monitoring]
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# OPTIONAL: Analytics
[external_services]
ANALYTICS_ID=your-analytics-id-here

# LOCAL PATHS (adjust if different on your machine)
[project]
PROJECT_ROOT=C:\dev\league-of-legends\info-lol-v0.0.3

# LOCAL DATABASE (use SQLite for development)
[database]
DATABASE_PATH=./data/summoners_chronicle.db

# LOCAL PORTS (adjust if ports are already in use)
[frontend]
FRONTEND_PORT=3000

[backend]
BACKEND_PORT=5000

[monitoring]
METRICS_PORT=8001

# DEVELOPMENT FLAGS (your preferences)
[development]
HOT_RELOAD_ENABLED=true
VERBOSE_LOGGING=true
MOCK_DATA_ENABLED=true
BROWSER_DEVTOOLS=true

# AI ASSISTANCE (enable if you want AI-assisted development)
[ai_assistance]
AI_ASSISTANCE_ENABLED=true
AI_BOILERPLATE_GENERATION=true
AI_DOCUMENTATION_GENERATION=true
AI_TEST_GENERATION=true

# =========================================================================
# DO NOT COMMIT THIS FILE - It contains sensitive credentials
# =========================================================================
