.sublime-workspace

# =========================================================================
# CRITICAL: NEVER COMMIT
# =========================================================================
# - API keys (RIOT_API_KEY, JWT_SECRET, etc.)
# - Database files with real data
# - Log files containing sensitive information
# - development.cfg.local or any .local configuration files
# - SSH keys or certificates
# - AWS credentials or authentication tokens
#
# If you accidentally committed a secret, use git-filter-branch to remove it:
#   git filter-branch --tree-filter 'rm -f <file>' HEAD
# =========================================================================
tmp*.cfg
